# =============================================================================
# Perfect Store — Root .gitignore
# Covers: Node.js API, Nuxt 3 Admin UI, OS & Editor files
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js

# -----------------------------------------------------------------------------
# Environment Variables (NEVER commit secrets)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Node.js / Express API (api/)
# -----------------------------------------------------------------------------
api/node_modules/
api/.env
api/.env.*
api/logs/
api/*.log
api/uploads/

# -----------------------------------------------------------------------------
# Nuxt 3 Admin UI (admin-ui/)
# -----------------------------------------------------------------------------
admin-ui/node_modules/

# Nuxt build & cache
admin-ui/.nuxt/
admin-ui/.output/
admin-ui/.cache/
admin-ui/dist/

# Nuxt dev server
admin-ui/.nitro/

# TypeScript
admin-ui/*.tsbuildinfo

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
coverage/
.nyc_output/

# -----------------------------------------------------------------------------
# Build Outputs
# -----------------------------------------------------------------------------
dist/
build/
out/

# -----------------------------------------------------------------------------
# Package Manager Lock Files (keep package-lock.json, ignore others)
# -----------------------------------------------------------------------------
yarn.lock
pnpm-lock.yaml

# -----------------------------------------------------------------------------
# OS Generated Files
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# -----------------------------------------------------------------------------
# Editor & IDE
# -----------------------------------------------------------------------------
# VS Code
.vscode/
!.vscode/extensions.json

# JetBrains (WebStorm, IntelliJ)
.idea/
*.iml

# Vim
*.swp
*.swo

# Sublime Text
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
*.zip
*.tar.gz
*.rar
.temp/
tmp/
